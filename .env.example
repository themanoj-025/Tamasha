# TMDb API credentials — required for movie enrichment (plot summaries, release dates, poster paths)
# Get yours free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_api_key_here
TMDB_ACCESS_TOKEN=your_access_token_here

# API key for authenticating requests (X-API-Key header)
# Change this to a strong random value in production!
API_KEY=tamasha-dev-key-2026

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8000,https://tamasha-dashboard.streamlit.app

# Global rate limit (slowapi format)
RATE_LIMIT=60/minute
