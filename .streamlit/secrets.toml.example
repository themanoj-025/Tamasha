# Tamasha — Streamlit Cloud Secrets Template
# Copy this file to secrets.toml and fill in your actual credentials.
# Do NOT commit secrets.toml to version control — it is gitignored.

# TMDb API credentials (for poster/image enrichment)
TMDB_API_KEY = "your_tmdb_api_key_here"
TMDB_ACCESS_TOKEN = "your_tmdb_access_token_here"

# API key for authenticating against the FastAPI backend
# (only needed if the dashboard runs separately from the API)
API_KEY = "your_api_key_here"
